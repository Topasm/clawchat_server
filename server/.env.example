# Server
HOST=127.0.0.1
PORT=8000

# Database
DATABASE_URL=sqlite+aiosqlite:///./data/clawchat.db

# Authentication
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRY_HOURS=24
PIN=replace-with-a-strong-random-pin

# AI — delegates to OpenClaw gateway
AI_BASE_URL=http://127.0.0.1:18789
AI_API_KEY=your-openclaw-gateway-token
AI_MODEL=openclaw
